# Server
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/school_management
# For Atlas: mongodb+srv://user:pass@cluster.mongodb.net/school_management

# JWT
JWT_SECRET=your_super_secret_jwt_key_min_32_chars_long
JWT_EXPIRES_IN=24h

# File uploads
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=5242880

# Visitor alert (minutes before MISSING alert)
VISITOR_ALERT_MINUTES=10

# School info
SCHOOL_NAME=Delhi Public School
